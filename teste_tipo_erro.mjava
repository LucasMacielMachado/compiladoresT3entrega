class Bateria {
    public int medirCarga() {
        int voltagem;
        boolean descarregada;
        
        voltagem = 12;
        descarregada = false;
        
        voltagem = descarregada; // atribuicao com tipo errado
        
        return voltagem;
    }
}

class App {
    public static void main(String[] args) {
        System.out.println(new Bateria().medirCarga());
    }
}