class Bateria {
    public int medirCarga() {
        int voltagem;
        boolean descarregada;
        
        voltagem = 12;
        descarregada = false;
        
        if (!descarregada) {
            voltagem = voltagem + 2;
        } else {
            voltagem = 0;
        }
        
        return voltagem;
    }
}

class App {
    public static void main(String[] args) {
        System.out.println(new Bateria().medirCarga());
    }
}